# Garage 2007 Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
# Default matches docker-compose.yml
DATABASE_URL=postgresql://garage:garage_dev_123@localhost:5432/garage2007

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather → /mybots → your bot → API Token
BOT_TOKEN=your_bot_token_here

# Random secret sent in X-Telegram-Bot-Api-Secret-Token header when setting webhook
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_random_secret_32chars_min

# ── Auth ─────────────────────────────────────────────────────────────────────
# Random secret for JWT signing — keep private, min 64 chars
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_random_secret_64chars_min

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
